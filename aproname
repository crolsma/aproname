#! /bin/sh

#### Detects invalid pathname lengths and patterns based on restrictions from:
#### POSIX Portable Filename Character Set,
#### ustar pathname length restrictions,
#### MS-DOS and Microsoft Windows restrictions,
#### and additional restrictions to avoid common usability problems.

## Only include ASCII characters in ranges,
## and count length by bytes.
export LC_COLLATE=C LC_CTYPE=C

awk '
	function alength(arr,    i, j)
	{
		i = 0
		for (j in arr) {
			++i
		}
		return i
	}

	function adelete(arr,    i)
	{
		for (i in arr) {
			delete arr[i]
		}
	}

	BEGIN {
		FS = "/"

		## array[criteria] = "error message prefix"
		byte[byte_pref = 156] = "Exceeds ustar prefix byte limit"
		byte[byte_name = 100] = "Exceeds ustar filename byte limit"
		patt["[^0-9A-Za-z._-]"] = "Contains non-portable character"
		patt["^(aux|con|nul|prn|(com|lpt)[0-9])([.].*)?$"] = \
			"Reserved MS-DOS name"
		patt["^[.]lock$|_vti_|^desktop[.]ini$"] = \
			"Restricted Microsoft OneDrive name"
		patt["^-|[.]$"] = "Invalid leading/trailing character"
		patt["^[^0-9A-Za-z]+$"] = "Only contains"

		form = "%s: %s: %s\n"
		sort = "sort"
		stat = 0

		for (i = 1; i < ARGC; ++i) {
			path = ARGV[i]; n = split(path, comp)

			if (n > 1 && length(path) - length(comp[n]) > byte_pref) {
				flag[byte_pref] = byte[byte_pref]
			}

			for (j = 1; j <= n; ++j) {
				if (comp[j] != "") {
					if (length(comp[j]) > byte_name) {
						flag[byte_name] = byte[byte_name]
					}

					for (k in patt) {
						if (tolower(comp[j]) ~ k) {
							flag[k] = patt[k]
						}
					}
				}
			}

			if (alength(flag) > 0) {
				stat = 1

				for (j in flag) {
					printf form, path, flag[j], j | sort
				}

				close(sort); adelete(flag)
			}
		}

		exit stat
	}
' "$@"
